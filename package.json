{
  "name": "accord-protocol-monorepo",
  "version": "0.4.0",
  "private": true,
  "description": "Monorepo root for the Accord Protocol open-source reference implementation. Hosts @accord-protocol/core (canonicalize / hash / validate the v0 protocol objects) plus the existing Ergo / Rosen / Base reference rail packages. The root package.json is private and exists only to configure workspaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bez111/accord-protocol"
  },
  "homepage": "https://github.com/bez111/accord-protocol",
  "bugs": {
    "url": "https://github.com/bez111/accord-protocol/issues"
  },
  "workspaces": [
    "packages/accord-core",
    "packages/accord-mcp",
    "packages/accord-gateway",
    "packages/accord-rails",
    "packages/ergo-agent-pay",
    "packages/ergo-agent-cli",
    "packages/ergo-agent-api",
    "packages/ergo-agent-mcp",
    "packages/ergo-agent-server",
    "packages/ergo-agent-scripts",
    "packages/ergo-agent-rosen",
    "packages/agentpay-base"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  }
}
