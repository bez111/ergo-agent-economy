  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bez111/ergo-agent-economy"
  },
  "homepage": "https://github.com/bez111/ergo-agent-economy",
  "bugs": {
    "url": "https://github.com/bez111/ergo-agent-economy/issues"
  },
  "workspaces": [
    "packages/ergo-agent-pay",
    "packages/ergo-agent-cli",
