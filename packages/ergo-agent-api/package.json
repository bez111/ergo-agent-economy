{
  "name": "ergo-agent-api",
  "version": "0.3.0",
  "description": "Pay-per-API middleware on top of ergo-agent-pay. Verifies Ergo Notes, enforces replay protection, and (optionally) redeems them — usable with Express, Connect, Fastify (via adapter), or as a pure handler.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test src/__tests__/*.test.ts"
  },
  "keywords": [
    "ergo",
    "blockchain",
    "agent",
    "ai-agent",
    "payments",
    "api",
    "middleware",
    "express",
    "402",
    "pay-per-request",
    "agent-economy"
  ],
  "author": "bez111",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bez111/accord-protocol"
  },
  "homepage": "https://github.com/bez111/accord-protocol/tree/main/packages/ergo-agent-api",
  "bugs": {
    "url": "https://github.com/bez111/accord-protocol/issues"
  },
  "dependencies": {
    "ergo-agent-pay": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
