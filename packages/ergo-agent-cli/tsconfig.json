{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src", "src/__tests__"],
  "exclude": ["node_modules", "dist"]
}
