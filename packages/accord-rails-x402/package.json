{
  "name": "@accord-protocol/rails-x402",
  "version": "0.4.0",
  "description": "Accord rail adapter for x402-compatible HTTP payments. Wraps any x402 facilitator (Coinbase, custom) into the AccordRailAdapter shape so x402 endpoints can settle Accord agreements atomically (pay_before_response).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test src/__tests__/*.test.ts"
  },
  "keywords": [
    "accord-protocol",
    "rails",
    "x402",
    "http-402",
    "facilitator",
    "agent-payments",
    "rail-adapter"
  ],
  "author": "bez111",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bez111/accord-protocol",
    "directory": "packages/accord-rails-x402"
  },
  "homepage": "https://github.com/bez111/accord-protocol/tree/main/packages/accord-rails-x402",
  "bugs": {
    "url": "https://github.com/bez111/accord-protocol/issues"
  },
  "dependencies": {
    "@accord-protocol/core": "^0.4.0",
    "@accord-protocol/rails": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
